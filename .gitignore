@'
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.dll
*.egg-info/
dist/
build/

# 虚拟环境
.venv/
venv/
env/
ENV/

# 输出文件夹
output/

# IDE 文件
.vscode/
.idea/
*.swp
*.swo
*~

# Obsidian 本地配置
.obsidian/

# 操作系统临时文件
.DS_Store
Thumbs.db

# 其他日志和备份文件
*.log
*.bak
'@ | Out-File -FilePath .gitignore -Encoding utf8